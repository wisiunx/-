
import sys
import os

sys.path.insert(0, os.getcwd())

from fastapi import FastAPI, HTTPException, Depends
from typing import List, Optional
from sqlalchemy.orm import Session

from app.db import get_db
from app.db import crud


app = FastAPI(
    title="Book API",
    description="API для управления книгами и категориями",
    version="1.0.0"
)


@app.get("/")
def read_root():
    return {"message": "Добро пожаловать в Book API!"}


@app.get("/categories/")
def get_all_categories(db: Session = Depends(get_db)):

    categories = crud.get_all_categories(db)
    return [{"id": c.id, "title": c.title} for c in categories]

@app.post("/categories/")
def create_category(title: str, db: Session = Depends(get_db)):

    existing = crud.get_category_by_title(db, title)
    if existing:
        raise HTTPException(status_code=400, detail="Категория с таким названием уже существует")
    
    category = crud.create_category(db, title)
    return {"id": category.id, "title": category.title}

@app.put("/categories/{category_id}")
def update_category(category_id: int, title: str, db: Session = Depends(get_db)):

    category = crud.get_category(db, category_id)
    if not category:
        raise HTTPException(status_code=404, detail="Категория не найдена")
    
    updated = crud.update_category(db, category_id, title)
    return {"id": updated.id, "title": updated.title}

@app.delete("/categories/{category_id}")
def delete_category(category_id: int, db: Session = Depends(get_db)):

    category = crud.get_category(db, category_id)
    if not category:
        raise HTTPException(status_code=404, detail="Категория не найдена")
    
    crud.delete_category(db, category_id)
    return {"message": "Категория успешно удалена"}

@app.get("/books/")
def get_all_books(
    category_id: Optional[int] = None,
    db: Session = Depends(get_db)
):

    if category_id:
        books = crud.get_books_by_category(db, category_id)
    else:
        books = crud.get_all_books(db)
    
    return [{
        "id": b.id,
        "title": b.title,
        "description": b.description,
        "price": b.price,
        "url": b.url,
        "category_id": b.category_id,
        "category_title": b.category.title
    } for b in books]

@app.get("/books/{book_id}")
def get_book(book_id: int, db: Session = Depends(get_db)):

    book = crud.get_book(db, book_id)
    if not book:
        raise HTTPException(status_code=404, detail="Книга не найдена")
    
    return {
        "id": book.id,
        "title": book.title,
        "description": book.description,
        "price": book.price,
        "url": book.url,
        "category_id": book.category_id,
        "category_title": book.category.title
    }

@app.post("/books/")
def create_book(
    title: str,
    description: str,
    price: float,
    category_id: int,
    url: str = "",
    db: Session = Depends(get_db)
):

    category = crud.get_category(db, category_id)
    if not category:
        raise HTTPException(status_code=404, detail="Категория не найдена")
    
    book = crud.create_book(db, title, description, price, category_id, url)
    return {
        "id": book.id,
        "title": book.title,
        "description": book.description,
        "price": book.price,
        "url": book.url,
        "category_id": book.category_id
    }

@app.put("/books/{book_id}")
def update_book(
    book_id: int,
    title: Optional[str] = None,
    description: Optional[str] = None,
    price: Optional[float] = None,
    url: Optional[str] = None,
    category_id: Optional[int] = None,
    db: Session = Depends(get_db)
):

    book = crud.get_book(db, book_id)
    if not book:
        raise HTTPException(status_code=404, detail="Книга не найдена")
    
    if category_id:
        category = crud.get_category(db, category_id)
        if not category:
            raise HTTPException(status_code=404, detail="Категория не найдена")
    
    updated = crud.update_book(db, book_id, title, description, price, url, category_id)
    return {
        "id": updated.id,
        "title": updated.title,
        "description": updated.description,
        "price": updated.price,
        "url": updated.url,
        "category_id": updated.category_id
    }

@app.delete("/books/{book_id}")
def delete_book(book_id: int, db: Session = Depends(get_db)):
    """Удалить книгу"""
    book = crud.get_book(db, book_id)
    if not book:
        raise HTTPException(status_code=404, detail="Книга не найдена")
    
    crud.delete_book(db, book_id)
    return {"message": "Книга успешно удалена"}
